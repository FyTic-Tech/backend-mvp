# Server
PORT=8000
ENVIRONMENT=development

# CORS — scheme + host only, no trailing slash
FRONTEND_URL=http://localhost:5173
# App frontend — set when the app is hosted on a different domain than the website
APP_FRONTEND_URL=

# Supabase — Project URL (not secret)
SUPABASE_URL=url

# Supabase — Service role key (Settings -> API -> service_role)
SUPABASE_SERVICE_KEY=eyJhbGci...

# Resend — get API key from resend.com (Supabase Send Email hook)
RESEND_API_KEY=re_...

# Supabase Send Email hook signing secret (Auth -> Hooks -> reveal secret)
SUPABASE_HOOK_SECRET=v1,...

# Supabase Database Webhook secret (any string you choose, set in webhook headers)
SUPABASE_WEBHOOK_SECRET=your_chosen_secret_here

# Supabase JWT secret (Settings -> API -> JWT Secret) — required for app auth
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Internal API key — checked in X-Internal-Key header for super_admin/internal_dev/internal_team routes
INTERNAL_API_KEY=your_internal_key_here

# Google Gemini API key — required for AI endpoints (summarize, analyze, scan, template import)
GEMINI_API_KEY=your_gemini_key_here
