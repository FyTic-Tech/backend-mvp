# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8000
# Set to "production" on the deployed server, "development" locally.
ENVIRONMENT=development

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Origin of the frontend — scheme + host only, no trailing slash, no path.
# Dev:  http://localhost:5173
# Prod: https://fytic.mx
FRONTEND_URL=http://localhost:5173

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — not a secret, same for every environment.
SUPABASE_URL=https://wzevtxexmrisogbpuzmx.supabase.co

# Service role key — Supabase → Settings → API → "service_role" (reveal + copy).
# ⚠️  Paste the entire key as ONE unbroken line. Never press Enter inside the value.
#     A JWT looks like:  eyJhbGci...header...  .  eyJpc3M...payload...  .  signature
#     Yours starts with: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<payload>.<signature>
